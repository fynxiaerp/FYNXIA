# Public (browser-safe) — safe to use in client components
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key

# SERVER ONLY — never prefix with NEXT_PUBLIC_
# These values must be set in Vercel Dashboard > Environment Variables
# NEVER commit the real values to git
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ENCRYPTION_KEY=64-char-hex-string-generate-with-node-e-require-crypto-randomBytes-32-toString-hex

# Auth redirect URL (used in password reset emails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend email API key (for invite emails — create account at resend.com)
RESEND_API_KEY=re_your_resend_api_key_here
# Resend from email address (optional; defaults to FYNXIA <onboarding@resend.dev> for dev)
# For production, use a verified domain: FYNXIA <noreply@fynxia.com.br>
RESEND_FROM_EMAIL=FYNXIA <onboarding@resend.dev>

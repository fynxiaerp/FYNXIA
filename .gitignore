# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (real secrets — never commit)
.env*
# but allow the example template (contains only placeholders, no real secrets)
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# Claude Code — local config (may contain tokens/secrets; never commit)
.claude/settings.local.json

# local scratch / temp
.firecrawl/
_docx_temp/

# MCP local config (contains real tokens/secrets — never commit)
.mcp.json

# Playwright MCP local cache/logs (browser-test artifacts)
.playwright-mcp/
